{
  "expo": {
    "name": "love today",
    "slug": "today-couple-diary",
    "scheme": "today",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "uk.terrylovesapp.lovetoday",
      "buildNumber": "9",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "일기에 사진을 첨부하기 위해 사진 보관함에 접근합니다.",
        "NSPhotoLibraryAddUsageDescription": "일기 사진을 사진 보관함에 저장하기 위해 접근합니다.",
        "NSLocationWhenInUseUsageDescription": "일기에 장소를 기록할 때 현재 위치를 지도에 표시하기 위해 접근합니다.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F5795C",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      "expo-apple-authentication",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F5795C"
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "사진을 앨범에 저장하기 위해 접근 권한이 필요해요.",
          "savePhotosPermission": "사진을 앨범에 저장하기 위해 접근 권한이 필요해요.",
          "isAccessMediaLocationEnabled": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "https://lovetoday.terrylovesapp.uk",
      "kakaoJsKey": "bddb8a32af4507ecf1ea402ea4c0ca7b",
      "kakaoRestKey": "be9e8e34057ddefce22d6f52732c3c7a",
      "kakaoRedirectUri": "https://lovetoday.terrylovesapp.uk/api/auth/kakao/callback",
      "router": {},
      "eas": {
        "projectId": "e7d11b8c-cbe4-43cf-85d0-0ec8cdf940bb"
      }
    }
  }
}
